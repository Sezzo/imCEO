# OpenCode Custom Backend Configuration
#
# This file configures Claude Code to use your custom backend instead of Anthropic's API.
# Copy this to .env and customize for your deployment.

# =============================================================================
# REQUIRED: Enable Custom Mode
# =============================================================================

# Enable custom/OpenCode mode (disables Anthropic OAuth and SDK)
CLAUDE_CODE_USE_CUSTOM=true

# Your custom backend API endpoint
ANTHROPIC_BASE_URL=http://localhost:3000

# API key for your custom backend
ANTHROPIC_API_KEY=your-api-key-here

# =============================================================================
# OPTIONAL: External Services
# =============================================================================

# Disable all external calls to Anthropic (analytics, telemetry, feedback, etc.)
OPEN_CODE_DISABLE_EXTERNAL=true

# Disable non-essential traffic (MCP registry prefetch, etc.)
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=true

# =============================================================================
# OPTIONAL: Default Models
# =============================================================================

# Set default models for OpenCode (these IDs will be sent to your backend)
OPENCODE_DEFAULT_SONNET_MODEL=opencode-sonnet-4
OPENCODE_DEFAULT_OPUS_MODEL=opencode-opus-4
OPENCODE_DEFAULT_HAIKU_MODEL=opencode-haiku-4

# =============================================================================
# OPTIONAL: API Configuration
# =============================================================================

# Request timeout in milliseconds (default: 600000 = 10 minutes)
API_TIMEOUT_MS=600000

# Maximum retries for failed requests (default: 3)
# API_MAX_RETRIES=3

# =============================================================================
# OPTIONAL: Debug & Logging
# =============================================================================

# Enable debug logging to stderr
DEBUG=true

# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# OPTIONAL: Features (your backend must support these)
# =============================================================================

# Enable thinking/reasoning (your backend must support thinking blocks)
ENABLE_THINKING=true

# Enable tool search (your backend must support deferred tool loading)
ENABLE_TOOL_SEARCH=true

# Enable prompt caching (your backend must support cache_control)
ENABLE_PROMPT_CACHING=true

# =============================================================================
# OPTIONAL: Custom OAuth (if your backend has its own auth)
# =============================================================================

# Skip built-in OAuth completely
# CLAUDE_CODE_AUTH_MODE=apikey

# Custom OAuth endpoints (if your backend provides OAuth)
# CLAUDE_CODE_CUSTOM_OAUTH_URL=https://your-auth-server.com

# =============================================================================
# NOTES:
# =============================================================================
#
# 1. Your backend MUST implement the Anthropic Messages API format:
#    - POST /v1/messages
#    - Request/Response format: https://docs.anthropic.com/en/api/messages
#    - Streaming via Server-Sent Events (SSE)
#
# 2. Features your backend should support:
#    - Text generation
#    - Tool use (function calling)
#    - Thinking/reasoning blocks (optional)
#    - Computer use (screenshots, input - optional)
#    - Prompt caching (optional)
#
# 3. Model IDs:
#    - opencode-sonnet-4 (balanced)
#    - opencode-opus-4 (powerful)
#    - opencode-haiku-4 (fast)
#
# 4. Example backend implementations:
#    - LiteLLM Proxy with Anthropic-compatible output
#    - Custom HTTP server implementing the Messages API
#    - OpenAI-compatible API with Anthropic format adapter
#
# 5. Authentication:
#    - By default, uses API key in Authorization: Bearer header
#    - OAuth can be enabled if your backend supports it
