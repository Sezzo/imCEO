// ============================================================================
// PRISMA SCHEMA ERWEITERUNG
// 
// Diese Models müssen zum bestehenden prisma/schema.prisma hinzugefügt werden
// 
// Anleitung:
// 1. Öffne prisma/schema.prisma
// 2. Füge diese Models am Ende der Datei hinzu (vor dem letzten `}` falls vorhanden)
// 3. Führe aus: npx prisma migrate dev --name add_agent_teams
// 4. Führe aus: npx prisma generate
// ============================================================================

// ============================================================================
// AGENT TEAMS - Extension für Multi-Agent Collaboration
// ============================================================================

enum TeamRuntimeState {
  active
  cleaning_up
  cleaned_up
  error
}

enum BackendType {
  in_process
  tmux
  iterm2
  subprocess
  container
}

enum TaskStatus {
  pending
  in_progress
  completed
  blocked
  cancelled
}

enum HookValidationStatus {
  pending
  validating
  passed
  blocked
  error
}

enum MessageType {
  text
  shutdown_request
  shutdown_response
  plan_approval_request
  plan_approval_response
  broadcast
  task_notification
  system
}

enum ResponseType {
  approve
  reject
}

enum ExecutionState {
  queued
  initializing
  running
  waiting_for_plan_approval
  idle
  shutting_down
  completed
  failed
  killed
}

enum AgentEventType {
  session_started
  session_initialized
  tool_called
  tool_completed
  tool_failed
  message_sent
  message_received
  message_broadcast
  plan_submitted
  plan_approved
  plan_rejected
  shutdown_requested
  shutdown_approved
  shutdown_rejected
  task_claimed
  task_completed
  task_blocked
  session_completed
  session_failed
  session_killed
  session_idle
  error
}

enum HookType {
  task_created
  task_completed
  teammate_idle
  teammate_shutdown
}

enum HookResult {
  success
  warning
  blocked
  error
}

enum IsolationType {
  worktree
  remote
  container
}

enum PermissionMode {
  default
  acceptEdits
  plan
  bypassPermissions
  auto
}

// ============================================================================
// CORE AGENT TEAMS MODELS
// ============================================================================

model AgentTeam {
  teamId            String            @id @default(uuid()) @map("team_id")
  teamName          String            @unique @map("team_name")
  description       String?
  companyId         String            @map("company_id")
  leadAgentId       String            @map("lead_agent_id")
  leadSessionId     String?           @map("lead_session_id")
  currentState      TeamRuntimeState  @default(active) @map("current_state")
  metadata          Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  company           Company           @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  members           AgentTeamMember[]
  tasks             AgentTask[]
  mailbox           TeamMailbox[]
  sessions          AgentTeamSession[]
  executionLogs     AgentExecutionLog[]

  @@index([companyId])
  @@index([currentState])
  @@map("agent_teams")
}

model AgentTeamMember {
  memberId          String            @id @default(uuid()) @map("member_id")
  teamId            String            @map("team_id")
  agentId           String            @map("agent_id")
  name              String
  agentType         String?           @map("agent_type")
  model             String?
  color             String?
  backendType       BackendType       @default(in_process) @map("backend_type")
  processId         String?           @map("process_id")
  sessionId         String?           @map("session_id")
  isActive          Boolean           @default(true) @map("is_active")
  isLeader          Boolean           @default(false) @map("is_leader")
  planModeRequired  Boolean           @default(false) @map("plan_mode_required")
  joinedAt          DateTime          @default(now()) @map("joined_at")
  leftAt            DateTime?         @map("left_at")

  team              AgentTeam         @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@index([teamId])
  @@index([agentId])
  @@index([isActive])
  @@map("agent_team_members")
}

model AgentTask {
  taskId            String            @id @default(uuid()) @map("task_id")
  teamId            String            @map("team_id")
  subject           String
  description       String?
  activeForm        String?           @map("active_form")
  status            TaskStatus        @default(pending)
  ownerAgentId      String?           @map("owner_agent_id")
  blockedBy         String[]          @default([]) @map("blocked_by")
  blocks            String[]          @default([]) @map("blocks")
  metadata          Json?
  hookValidationStatus  HookValidationStatus @default(passed) @map("hook_validation_status")
  hookValidationErrors  String?         @map("hook_validation_errors")
  createdAt         DateTime          @default(now()) @map("created_at")
  claimedAt         DateTime?         @map("claimed_at")
  completedAt       DateTime?         @map("completed_at")

  team              AgentTeam         @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@index([teamId])
  @@index([status])
  @@index([ownerAgentId])
  @@index([blockedBy])
  @@map("agent_tasks")
}

model TeamMailbox {
  messageId         String            @id @default(uuid()) @map("message_id")
  teamId            String            @map("team_id")
  toAgentId         String            @map("to_agent_id")
  fromAgentId       String            @map("from_agent_id")
  messageType       MessageType       @default(text) @map("message_type")
  content           String
  summary           String?
  isRead            Boolean           @default(false) @map("is_read")
  readAt            DateTime?         @map("read_at")
  isProcessed       Boolean           @default(false) @map("is_processed")
  processedAt       DateTime?         @map("processed_at")
  requestId         String?           @map("request_id")
  responseType      ResponseType?     @map("response_type")
  feedback          String?
  createdAt         DateTime          @default(now()) @map("created_at")

  team              AgentTeam         @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@index([teamId])
  @@index([toAgentId])
  @@index([isRead])
  @@index([isProcessed])
  @@index([createdAt])
  @@map("team_mailbox")
}

model AgentTeamSession {
  sessionId         String            @id @default(uuid()) @map("session_id")
  teamId            String            @map("team_id")
  agentId           String            @map("agent_id")
  parentSessionId   String?           @map("parent_session_id")
  prompt            String
  description       String?
  executionState    ExecutionState    @default(queued) @map("execution_state")
  awaitingPlanApproval  Boolean         @default(false) @map("awaiting_plan_approval")
  planSubmitted     Boolean           @default(false) @map("plan_submitted")
  planContent       String?           @map("plan_content")
  planApproved      Boolean?          @map("plan_approved")
  planFeedback      String?           @map("plan_feedback")
  shutdownRequested Boolean           @default(false) @map("shutdown_requested")
  shutdownApproved  Boolean?          @map("shutdown_approved")
  shutdownReason    String?           @map("shutdown_reason")
  accumulatedCost   Decimal           @default(0) @map("accumulated_cost") @db.Decimal(10, 4)
  accumulatedTokens Int               @default(0) @map("accumulated_tokens")
  createdAt         DateTime          @default(now()) @map("created_at")
  startedAt         DateTime?         @map("started_at")
  lastActiveAt      DateTime?         @map("last_active_at")
  endedAt           DateTime?         @map("ended_at")

  team              AgentTeam         @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@index([teamId])
  @@index([agentId])
  @@index([executionState])
  @@map("agent_team_sessions")
}

model AgentExecutionLog {
  logId             String            @id @default(uuid()) @map("log_id")
  sessionId         String            @map("session_id")
  agentId           String            @map("agent_id")
  teamId            String            @map("team_id")
  eventType         AgentEventType    @map("event_type")
  eventData         Json              @map("event_data")
  toolName          String?           @map("tool_name")
  model             String?
  tokenCount        Int?              @map("token_count")
  costAmount        Decimal?          @map("cost_amount") @db.Decimal(10, 6)
  createdAt         DateTime          @default(now()) @map("created_at")

  team              AgentTeam         @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@index([sessionId])
  @@index([agentId])
  @@index([teamId])
  @@index([eventType])
  @@index([createdAt])
  @@map("agent_execution_logs")
}

model AgentHook {
  hookId            String            @id @default(uuid()) @map("hook_id")
  teamId            String            @map("team_id")
  hookType          HookType          @map("hook_type")
  name              String
  scriptContent     String            @map("script_content")
  isEnabled         Boolean           @default(true) @map("is_enabled")
  timeoutMs         Int               @default(30000) @map("timeout_ms")
  blocking          Boolean           @default(true)
  executionCount    Int               @default(0) @map("execution_count")
  lastExecutedAt    DateTime?         @map("last_executed_at")
  lastResult        HookResult?       @map("last_result")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([teamId])
  @@index([hookType])
  @@index([isEnabled])
  @@map("agent_hooks")
}

model AgentDefinition {
  definitionId      String            @id @default(uuid()) @map("definition_id")
  companyId         String            @map("company_id")
  identifier        String            @unique
  displayName       String            @map("display_name")
  description       String?
  whenToUse         String            @map("when_to_use")
  systemPrompt      String            @map("system_prompt")
  model             String?
  color             String?
  allowedTools      String[]          @default([]) @map("allowed_tools")
  requiredMcpServers String[]         @default([]) @map("required_mcp_servers")
  background        Boolean           @default(false)
  isolation         IsolationType?
  planModeRequired  Boolean           @default(false) @map("plan_mode_required")
  isGlobal          Boolean           @default(false) @map("is_global")
  isBuiltIn         Boolean           @default(false) @map("is_built_in")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([identifier])
  @@map("agent_definitions")
}

model AgentPermissionContext {
  contextId         String            @id @default(uuid()) @map("context_id")
  agentId           String            @map("agent_id")
  teamId            String?           @map("team_id")
  permissionMode    PermissionMode    @default(acceptEdits) @map("permission_mode")
  allowedTools      String[]          @default([]) @map("allowed_tools")
  deniedTools       String[]          @default([]) @map("denied_tools")
  allowedAgentTypes String[]          @default([]) @map("allowed_agent_types")
  deniedAgentTypes  String[]          @default([]) @map("denied_agent_types")
  additionalWorkingDirectories String[] @default([]) @map("additional_working_directories")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([teamId])
  @@map("agent_permission_contexts")
}

