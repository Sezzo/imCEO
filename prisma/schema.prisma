generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Organization
model Company {
  companyId          String    @id @default(uuid()) @map("company_id")
  name               String
  description        String?
  industry           String?
  primaryObjective   String?   @map("primary_objective")
  operatingMode      String?   @map("operating_mode")
  globalPrompt       String?   @map("global_prompt")
  globalPolicies     Json?     @map("global_policies")
  globalSkills       Json?     @map("global_skills")
  globalMcps         Json?     @map("global_mcps")
  globalPlugins      Json?     @map("global_plugins")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  divisions          Division[]
  teams              Team[]
  roleTemplates      RoleTemplate[]
  agentProfiles      AgentProfile[]
  workItems          WorkItem[]
  artifacts          Artifact[]
  policies           Policy[]
  modelProfiles      ModelProfile[]
  reportingLines     ReportingLine[]
  escalationChains   EscalationChain[]

  // Phase C relations
  skillDefinitions   SkillDefinition[]
  skillBundles       SkillBundle[]
  mcpDefinitions     MCPDefinition[]
  mcpBundles         MCPBundle[]
  pluginDefinitions PluginDefinition[]
  pluginBundles      PluginBundle[]
  costBudgets        CostBudget[]

  @@map("companies")
}

model Division {
  divisionId        String    @id @default(uuid()) @map("division_id")
  companyId         String    @map("company_id")
  name              String
  description       String?
  parentDivisionId  String?   @map("parent_division_id")
  headRoleId        String?   @map("head_role_id")
  policies          Json?
  defaultWorkflows  Json?     @map("default_workflows")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company           Company   @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  departments       Department[]
  parentDivision    Division? @relation("DivisionHierarchy", fields: [parentDivisionId], references: [divisionId])
  childDivisions    Division[] @relation("DivisionHierarchy")

  @@map("divisions")
}

model Department {
  departmentId      String    @id @default(uuid()) @map("department_id")
  divisionId        String    @map("division_id")
  name              String
  description       String?
  headRoleId        String?   @map("head_role_id")
  scope             String?
  policies          Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  division          Division  @relation(fields: [divisionId], references: [divisionId], onDelete: Cascade)
  teams             Team[]

  @@map("departments")
}

model Team {
  teamId                String    @id @default(uuid()) @map("team_id")
  departmentId          String    @map("department_id")
  companyId             String?   @map("company_id")
  name                  String
  description           String?
  mission               String?
  teamType              String?   @map("team_type")
  leadRoleId            String?   @map("lead_role_id")
  defaultModelProfileId String?   @map("default_model_profile_id")
  defaultSkillBundleId  String?   @map("default_skill_bundle_id")
  defaultMcpBundleId    String?   @map("default_mcp_bundle_id")
  allowedInteractions   Json?     @map("allowed_interactions")
  escalationChainId     String?   @map("escalation_chain_id")
  costBudgetPolicyId    String?   @map("cost_budget_policy_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  department            Department @relation(fields: [departmentId], references: [departmentId], onDelete: Cascade)
  company               Company?   @relation(fields: [companyId], references: [companyId])
  agentProfiles         AgentProfile[]
  workItems             WorkItem[]

  @@map("teams")
}

// Roles & Agents
enum HierarchyLevel {
  CEO
  Executive
  Management
  Lead
  Specialist
  Governance
  Observer
}

model RoleTemplate {
  roleTemplateId      String          @id @default(uuid()) @map("role_template_id")
  companyId           String          @map("company_id")
  name                String
  hierarchyLevel      HierarchyLevel  @map("hierarchy_level")
  description         String?
  purpose             String?
  primaryResponsibilities Json?       @map("primary_responsibilities")
  nonResponsibilities Json?           @map("non_responsibilities")
  decisionScope       Json?           @map("decision_scope")
  escalationScope     Json?           @map("escalation_scope")
  requiredArtifacts   Json?           @map("required_artifacts")
  requiredReviews     Json?           @map("required_reviews")
  defaultModelProfileId String?       @map("default_model_profile_id")
  defaultSkillBundleId  String?       @map("default_skill_bundle_id")
  costClass           String?         @map("cost_class")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  company             Company         @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  agentProfiles       AgentProfile[]

  @@map("role_templates")
}

model AgentProfile {
  agentId               String    @id @default(uuid()) @map("agent_id")
  teamId                String    @map("team_id")
  companyId             String?   @map("company_id")
  roleTemplateId        String?   @map("role_template_id")
  displayName           String    @map("display_name")
  internalName          String    @map("internal_name")
  seniority             String?
  status                String    @default("active")
  customPromptOverride  String?   @map("custom_prompt_override")
  maxParallelTasks      Int       @default(1) @map("max_parallel_tasks")
  maxContextBudget      Int?      @map("max_context_budget")
  maxCostPerTask        Decimal?  @map("max_cost_per_task") @db.Decimal(10, 2)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  team                  Team      @relation(fields: [teamId], references: [teamId], onDelete: Cascade)
  company               Company?  @relation(fields: [companyId], references: [companyId])
  roleTemplate          RoleTemplate? @relation(fields: [roleTemplateId], references: [roleTemplateId])
  workItems             WorkItem[]

  @@map("agent_profiles")
}

// Work Domain
enum WorkItemType {
  Vision
  Goal
  Initiative
  Program
  Workstream
  Epic
  Story
  Task
  Subtask
  Bug
  Spike
  ReviewTask
  TestTask
  ReleaseTask
}

enum WorkItemState {
  Draft
  Proposed
  Approved
  Planned
  Ready
  InProgress
  WaitingOnDependency
  InReview
  ChangesRequested
  InTest
  AwaitingApproval
  ApprovedForCompletion
  Done
  Archived
  Reopened
  Rejected
  Cancelled
}

model WorkItem {
  workItemId        String        @id @default(uuid()) @map("work_item_id")
  type              WorkItemType
  title             String
  description       String?
  parentWorkItemId  String?       @map("parent_work_item_id")
  companyId         String?       @map("company_id")
  divisionId        String?       @map("division_id")
  departmentId      String?       @map("department_id")
  owningTeamId      String?       @map("owning_team_id")
  owningRoleId      String?       @map("owning_role_id")
  assignedAgentId   String?       @map("assigned_agent_id")
  priority          String?
  severity          String?
  state             WorkItemState @default(Draft)
  approvalState     String?       @map("approval_state")
  riskScore         Int?          @map("risk_score")
  costLimit         Decimal?      @map("cost_limit") @db.Decimal(10, 2)
  estimatedEffort   Int?          @map("estimated_effort")
  actualEffort      Int?          @map("actual_effort")
  createdAt         DateTime      @default(now()) @map("created_at")
  startedAt         DateTime?     @map("started_at")
  dueAt             DateTime?     @map("due_at")
  completedAt       DateTime?     @map("completed_at")

  company           Company?      @relation(fields: [companyId], references: [companyId])
  team              Team?         @relation(fields: [owningTeamId], references: [teamId])
  agent             AgentProfile? @relation(fields: [assignedAgentId], references: [agentId])
  parentWorkItem    WorkItem?     @relation("WorkItemHierarchy", fields: [parentWorkItemId], references: [workItemId])
  childWorkItems    WorkItem[]    @relation("WorkItemHierarchy")
  artifacts         Artifact[]
  history           WorkItemHistory[]

  @@map("work_items")
}

model WorkItemHistory {
  historyId       String          @id @default(uuid()) @map("history_id")
  workItemId      String          @map("work_item_id")
  fromState       WorkItemState   @map("from_state")
  toState         WorkItemState   @map("to_state")
  reason          String?
  actorId         String?         @map("actor_id")
  actorType       String?         @map("actor_type")
  createdAt       DateTime        @default(now()) @map("created_at")

  workItem        WorkItem        @relation(fields: [workItemId], references: [workItemId], onDelete: Cascade)

  @@index([workItemId])
  @@index([createdAt])
  @@map("work_item_history")
}

enum DelegationType {
  research
  planning
  analysis
  architecture
  implementation
  testing
  review
  documentation
  compliance
  release_preparation
  incident_response
  remediation
}

enum DelegationState {
  pending
  accepted
  in_progress
  completed
  failed
  cancelled
}

model Delegation {
  delegationId          String          @id @default(uuid()) @map("delegation_id")
  sourceWorkItemId      String          @map("source_work_item_id")
  sourceAgentId         String?         @map("source_agent_id")
  sourceRoleId          String?         @map("source_role_id")
  targetTeamId          String          @map("target_team_id")
  targetRoleId          String?         @map("target_role_id")
  targetAgentId         String?         @map("target_agent_id")
  delegationType        DelegationType  @map("delegation_type")
  objective             String?
  scope                 String?
  constraints           Json?
  state                 DelegationState @default(pending)
  costLimit             Decimal?        @map("cost_limit") @db.Decimal(10, 2)
  createdAt             DateTime        @default(now()) @map("created_at")
  acceptedAt            DateTime?       @map("accepted_at")
  completedAt           DateTime?       @map("completed_at")
  failedAt              DateTime?       @map("failed_at")

  @@map("delegations")
}

// Artifacts
enum ArtifactType {
  VisionBrief
  StrategicMemo
  GoalDefinition
  ArchitectureProposal
  ADR
  SystemDesign
  TechnicalSpec
  APIContract
  TaskBrief
  TestPlan
  TestReport
  ReviewReport
  DocumentationDraft
  ReleaseNotes
  SecurityReview
  ComplianceReport
}

enum ArtifactStatus {
  Draft
  InPreparation
  UnderReview
  Approved
  Superseded
  Archived
}

model Artifact {
  artifactId        String          @id @default(uuid()) @map("artifact_id")
  companyId         String?         @map("company_id")
  type              ArtifactType
  title             String
  description       String?
  status            ArtifactStatus  @default(Draft)
  version           String          @default("1.0.0")
  ownerTeamId       String?         @map("owner_team_id")
  ownerAgentId      String?         @map("owner_agent_id")
  sourceWorkItemId  String?         @map("source_work_item_id")
  content           String?
  contentHash       String?         @map("content_hash")
  storageUri        String?         @map("storage_uri")
  approvalState     String?         @map("approval_state")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  company           Company?        @relation(fields: [companyId], references: [companyId])
  workItem          WorkItem?       @relation(fields: [sourceWorkItemId], references: [workItemId])
  reviews           Review[]

  @@map("artifacts")
}

enum ReviewType {
  peer_review
  lead_review
  architecture_review
  qa_review
  security_review
  compliance_review
  executive_review
}

enum ReviewResult {
  approved
  approved_with_notes
  changes_requested
  rejected
  escalated
}

model Review {
  reviewId          String        @id @default(uuid()) @map("review_id")
  reviewType        ReviewType    @map("review_type")
  targetWorkItemId  String?       @map("target_work_item_id")
  targetArtifactId  String?       @map("target_artifact_id")
  reviewerRoleId    String?       @map("reviewer_role_id")
  reviewerAgentId   String?       @map("reviewer_agent_id")
  result            ReviewResult?
  findings          String?
  mandatoryFixes    Json?         @map("mandatory_fixes")
  optionalNotes     String?       @map("optional_notes")
  severity          String?
  createdAt         DateTime      @default(now()) @map("created_at")
  resolvedAt        DateTime?     @map("resolved_at")

  artifact          Artifact?     @relation(fields: [targetArtifactId], references: [artifactId])

  @@map("reviews")
}

// Governance
enum PolicyType {
  tool_policy
  mcp_policy
  plugin_policy
  skill_policy
  filesystem_policy
  git_policy
  review_policy
  test_policy
  release_policy
  budget_policy
  escalation_policy
}

enum PolicyAction {
  allow
  allow_with_warning
  require_approval
  block
  quarantine
  escalate
}

model Policy {
  policyId            String      @id @default(uuid()) @map("policy_id")
  name                String
  description         String?
  policyType          PolicyType  @map("policy_type")
  scopeType           String      @map("scope_type")
  scopeId             String      @map("scope_id")
  conditionExpression String?     @map("condition_expression")
  action              PolicyAction
  severity            String?
  approvalRequirement String?     @map("approval_requirement")
  enabled             Boolean     @default(true)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  company             Company     @relation(fields: [scopeId], references: [companyId])

  @@map("policies")
}

enum ApprovalRequestState {
  pending
  approved
  rejected
  escalated
  expired
}

model ApprovalRequest {
  approvalRequestId       String              @id @default(uuid()) @map("approval_request_id")
  targetType              String              @map("target_type")
  targetId                String              @map("target_id")
  reason                  String?
  requestedByRoleId       String              @map("requested_by_role_id")
  requestedByAgentId    String?             @map("requested_by_agent_id")
  requiredApproverRoleIds Json?             @map("required_approver_role_ids")
  state                   ApprovalRequestState @default(pending)
  expiresAt               DateTime?           @map("expires_at")
  approvedAt              DateTime?           @map("approved_at")
  rejectedAt              DateTime?           @map("rejected_at")
  escalatedAt             DateTime?           @map("escalated_at")

  @@map("approval_requests")
}

// Model Profiles & Configuration
model ModelProfile {
  modelProfileId      String    @id @default(uuid()) @map("model_profile_id")
  companyId           String    @map("company_id")
  name                String
  modelVariant        String    @map("model_variant")
  description         String?
  contextWindow       Int       @map("context_window")
  maxOutputTokens     Int       @map("max_output_tokens")
  capabilities        Json?
  inputCostPer1k      Decimal   @map("input_cost_per_1k") @db.Decimal(10, 6)
  outputCostPer1k     Decimal   @map("output_cost_per_1k") @db.Decimal(10, 6)
  cachingEnabled      Boolean   @default(false) @map("caching_enabled")
  cachingCostPer1k    Decimal?  @map("caching_cost_per_1k") @db.Decimal(10, 6)
  batchingEnabled     Boolean   @default(false) @map("batching_enabled")
  batchingDiscount    Decimal?  @map("batching_discount") @db.Decimal(3, 2)
  isDefault           Boolean   @default(false) @map("is_default")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company             Company   @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId])
  @@map("model_profiles")
}

// Reporting & Escalation
enum ReportingLineType {
  direct
  dotted
  functional
  matrix
}

model ReportingLine {
  reportingLineId     String            @id @default(uuid()) @map("reporting_line_id")
  companyId           String            @map("company_id")
  reporterRoleId      String?           @map("reporter_role_id")
  reporterAgentId     String?           @map("reporter_agent_id")
  reportsToRoleId     String?           @map("reports_to_role_id")
  reportsToAgentId    String?           @map("reports_to_agent_id")
  reportingLineType   ReportingLineType @map("reporting_line_type")
  isPrimary           Boolean           @default(true) @map("is_primary")
  scope               String?
  startDate           DateTime          @default(now()) @map("start_date")
  endDate             DateTime?         @map("end_date")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  company             Company           @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId])
  @@index([reporterRoleId])
  @@index([reportsToRoleId])
  @@map("reporting_lines")
}

enum EscalationTrigger {
  time_based
  failure_based
  cost_based
  manual
  policy_violation
  blocked
}

enum EscalationState {
  active
  triggered
  resolved
  cancelled
}

model EscalationChain {
  escalationChainId   String            @id @default(uuid()) @map("escalation_chain_id")
  companyId           String            @map("company_id")
  name                String
  description         String?
  triggerType         EscalationTrigger @map("trigger_type")
  triggerCondition    String            @map("trigger_condition")
  level1RoleId        String            @map("level_1_role_id")
  level2RoleId        String?           @map("level_2_role_id")
  level3RoleId        String?           @map("level_3_role_id")
  autoEscalateTime    Int?              @map("auto_escalate_time")
  notifyOnTrigger     Boolean           @default(true) @map("notify_on_trigger")
  state               EscalationState   @default(active)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  company             Company           @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  escalationEvents    EscalationEvent[]

  @@index([companyId])
  @@map("escalation_chains")
}

model EscalationEvent {
  escalationEventId   String          @id @default(uuid()) @map("escalation_event_id")
  escalationChainId   String          @map("escalation_chain_id")
  targetType          String          @map("target_type")
  targetId            String          @map("target_id")
  triggeredBy         String?         @map("triggered_by")
  triggerReason       String          @map("trigger_reason")
  currentLevel        Int             @map("current_level")
  escalatedToRoleId   String?         @map("escalated_to_role_id")
  escalatedToAgentId  String?         @map("escalated_to_agent_id")
  resolvedAt          DateTime?       @map("resolved_at")
  resolution          String?
  createdAt           DateTime        @default(now()) @map("created_at")

  escalationChain     EscalationChain @relation(fields: [escalationChainId], references: [escalationChainId], onDelete: Cascade)

  @@index([escalationChainId])
  @@index([targetId])
  @@map("escalation_events")
}

// Runtime
enum TeamSessionState {
  Queued
  Launching
  Active
  Waiting
  Idle
  Failed
  Completed
  Terminated
}

enum AgentSessionState {
  Assigned
  Running
  Waiting
  Idle
  Blocked
  Failed
  Completed
  Killed
}

model TeamSession {
  teamSessionId         String          @id @default(uuid()) @map("team_session_id")
  teamId                String          @map("team_id")
  initiatingWorkItemId  String?         @map("initiating_work_item_id")
  sessionPurpose        String?         @map("session_purpose")
  currentState          TeamSessionState @default(Queued)
  currentCost           Decimal         @default(0) @map("current_cost") @db.Decimal(10, 2)
  currentContextUsage   Int             @default(0) @map("current_context_usage")
  launchedAt            DateTime?       @map("launched_at")
  endedAt               DateTime?       @map("ended_at")

  agentSessions         AgentSession[]

  @@map("team_sessions")
}

model AgentSession {
  agentSessionId      String          @id @default(uuid()) @map("agent_session_id")
  teamSessionId       String          @map("team_session_id")
  agentId             String          @map("agent_id")
  assignedWorkItemId  String?         @map("assigned_work_item_id")
  state               AgentSessionState @default(Assigned)
  costAccumulated     Decimal         @default(0) @map("cost_accumulated") @db.Decimal(10, 2)
  contextAccumulated  Int             @default(0) @map("context_accumulated")
  startedAt           DateTime?       @map("started_at")
  lastActiveAt        DateTime?       @map("last_active_at")
  endedAt             DateTime?       @map("ended_at")
  failureReason       String?         @map("failure_reason")

  teamSession         TeamSession     @relation(fields: [teamSessionId], references: [teamSessionId])

  @@map("agent_sessions")
}

// Observability
enum AuditEventType {
  company_created
  company_updated
  division_created
  team_created
  work_item_created
  work_item_state_changed
  work_item_completed
  delegation_created
  delegation_completed
  decision_approved
  approval_requested
  policy_violation
  cost_threshold_reached
  agent_session_failed
}

enum AuditSeverity {
  info
  warning
  critical
}

model AuditEvent {
  auditEventId    String          @id @default(uuid()) @map("audit_event_id")
  eventType       AuditEventType  @map("event_type")
  actorRoleId     String?         @map("actor_role_id")
  actorAgentId    String?         @map("actor_agent_id")
  targetType      String          @map("target_type")
  targetId        String          @map("target_id")
  description     String?
  payload         Json?
  severity        AuditSeverity
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([eventType])
  @@index([targetId])
  @@map("audit_events")
}

model CostRecord {
  costRecordId    String    @id @default(uuid()) @map("cost_record_id")
  scopeType       String    @map("scope_type")
  scopeId         String    @map("scope_id")
  teamId          String?   @map("team_id")
  agentId         String?   @map("agent_id")
  modelProfileId  String?   @map("model_profile_id")
  workItemId      String?   @map("work_item_id")
  costType        String    @map("cost_type")
  value           Decimal   @db.Decimal(10, 2)
  unit            String    @default("USD")
  details         Json?
  recordedAt      DateTime  @default(now()) @map("recorded_at")

  @@index([recordedAt])
  @@index([scopeId])
  @@map("cost_records")
}

// ============================================================================
// GOVERNANCE LAYER - PHASE C
// ============================================================================

// Skill Management
enum SkillInvocationMode {
  autonomous
  interactive
  approval_required
}

enum SkillCategory {
  communication
  research
  analysis
  coding
  testing
  devops
  design
  security
  compliance
  custom
}

model SkillDefinition {
  skillId           String              @id @default(uuid()) @map("skill_id")
  companyId         String              @map("company_id")
  name              String
  description       String?
  category          SkillCategory       @default(custom)
  invocationMode    SkillInvocationMode @default(interactive) @map("invocation_mode")
  inputSchema       Json?               @map("input_schema")
  outputSchema      Json?               @map("output_schema")
  requiredPermissions Json?             @map("required_permissions")
  configuration     Json?
  version           String              @default("1.0.0")
  isGlobal          Boolean             @default(false) @map("is_global")
  enabled           Boolean             @default(true)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  company           Company             @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  bundleItems       SkillBundleItem[]
  assignments       SkillAssignment[]

  @@index([companyId])
  @@index([category])
  @@map("skill_definitions")
}

model SkillBundle {
  bundleId          String            @id @default(uuid()) @map("bundle_id")
  companyId         String            @map("company_id")
  name              String
  description       String?
  category          String?
  isGlobal          Boolean           @default(false) @map("is_global")
  enabled           Boolean           @default(true)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  items             SkillBundleItem[]

  @@index([companyId])
  @@map("skill_bundles")
}

model SkillBundleItem {
  itemId            String          @id @default(uuid()) @map("item_id")
  bundleId          String          @map("bundle_id")
  skillId           String          @map("skill_id")
  configuration     Json?
  priority          Int             @default(0)
  addedAt           DateTime        @default(now()) @map("added_at")

  bundle            SkillBundle     @relation(fields: [bundleId], references: [bundleId], onDelete: Cascade)
  skill             SkillDefinition @relation(fields: [skillId], references: [skillId], onDelete: Cascade)

  @@unique([bundleId, skillId])
  @@map("skill_bundle_items")
}

enum SkillAssignmentScope {
  team
  agent
  role_template
}

model SkillAssignment {
  assignmentId      String               @id @default(uuid()) @map("assignment_id")
  skillId           String               @map("skill_id")
  scopeType         SkillAssignmentScope @map("scope_type")
  scopeId           String               @map("scope_id")
  configuration     Json?
  overrideMode      SkillInvocationMode? @map("override_mode")
  enabled           Boolean              @default(true)
  assignedAt        DateTime             @default(now()) @map("assigned_at")
  assignedBy        String?              @map("assigned_by")

  skill             SkillDefinition      @relation(fields: [skillId], references: [skillId], onDelete: Cascade)

  @@index([skillId])
  @@index([scopeType, scopeId])
  @@map("skill_assignments")
}

// MCP Management
enum MCPAuthType {
  none
  api_key
  oauth
  basic
  bearer
}

enum MCPHealthStatus {
  healthy
  degraded
  unhealthy
  unknown
}

model MCPDefinition {
  mcpId             String           @id @default(uuid()) @map("mcp_id")
  companyId         String           @map("company_id")
  name              String
  description       String?
  serverUrl         String           @map("server_url")
  capabilities      Json?
  authType          MCPAuthType      @default(none) @map("auth_type")
  authConfig        Json?            @map("auth_config")
  healthStatus      MCPHealthStatus  @default(unknown) @map("health_status")
  lastHealthCheck   DateTime?        @map("last_health_check")
  healthCheckConfig Json?            @map("health_check_config")
  isGlobal          Boolean          @default(false) @map("is_global")
  enabled           Boolean          @default(true)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  company           Company          @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  bundleItems       MCPBundleItem[]
  assignments       MCPAssignment[]

  @@index([companyId])
  @@map("mcp_definitions")
}

model MCPBundle {
  bundleId          String          @id @default(uuid()) @map("bundle_id")
  companyId         String          @map("company_id")
  name              String
  description       String?
  category          String?
  isGlobal          Boolean         @default(false) @map("is_global")
  enabled           Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  company           Company         @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  items             MCPBundleItem[]

  @@index([companyId])
  @@map("mcp_bundles")
}

model MCPBundleItem {
  itemId            String        @id @default(uuid()) @map("item_id")
  bundleId          String        @map("bundle_id")
  mcpId             String        @map("mcp_id")
  configuration     Json?
  priority          Int           @default(0)
  addedAt           DateTime      @default(now()) @map("added_at")

  bundle            MCPBundle     @relation(fields: [bundleId], references: [bundleId], onDelete: Cascade)
  mcp               MCPDefinition @relation(fields: [mcpId], references: [mcpId], onDelete: Cascade)

  @@unique([bundleId, mcpId])
  @@map("mcp_bundle_items")
}

enum MCPAssignmentScope {
  team
  agent
  role_template
}

model MCPAssignment {
  assignmentId      String             @id @default(uuid()) @map("assignment_id")
  mcpId             String             @map("mcp_id")
  scopeType         MCPAssignmentScope @map("scope_type")
  scopeId           String             @map("scope_id")
  configuration     Json?
  enabled           Boolean            @default(true)
  assignedAt        DateTime           @default(now()) @map("assigned_at")
  assignedBy        String?            @map("assigned_by")

  mcp               MCPDefinition      @relation(fields: [mcpId], references: [mcpId], onDelete: Cascade)

  @@index([mcpId])
  @@index([scopeType, scopeId])
  @@map("mcp_assignments")
}

// Plugin Management
enum PluginType {
  tool
  integration
  extension
  theme
}

enum PluginStatus {
  pending
  installing
  active
  updating
  error
  disabled
}

model PluginDefinition {
  pluginId          String         @id @default(uuid()) @map("plugin_id")
  companyId         String         @map("company_id")
  name              String
  description       String?
  version           String         @default("1.0.0")
  pluginType        PluginType     @default(extension) @map("plugin_type")
  sourceUrl         String?        @map("source_url")
  entryPoint        String         @map("entry_point")
  permissions       Json?
  configuration     Json?
  dependencies      Json?
  isGlobal          Boolean        @default(false) @map("is_global")
  status            PluginStatus   @default(pending)
  enabled           Boolean        @default(true)
  installedAt       DateTime?      @map("installed_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  company           Company        @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  bundleItems       PluginBundleItem[]
  assignments       PluginAssignment[]

  @@index([companyId])
  @@map("plugin_definitions")
}

model PluginBundle {
  bundleId          String         @id @default(uuid()) @map("bundle_id")
  companyId         String         @map("company_id")
  name              String
  description       String?
  category          String?
  isGlobal          Boolean        @default(false) @map("is_global")
  enabled           Boolean        @default(true)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  company           Company        @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  items             PluginBundleItem[]

  @@index([companyId])
  @@map("plugin_bundles")
}

model PluginBundleItem {
  itemId            String         @id @default(uuid()) @map("item_id")
  bundleId          String         @map("bundle_id")
  pluginId          String         @map("plugin_id")
  configuration     Json?
  priority          Int            @default(0)
  addedAt           DateTime       @default(now()) @map("added_at")

  bundle            PluginBundle   @relation(fields: [bundleId], references: [bundleId], onDelete: Cascade)
  plugin            PluginDefinition @relation(fields: [pluginId], references: [pluginId], onDelete: Cascade)

  @@unique([bundleId, pluginId])
  @@map("plugin_bundle_items")
}

enum PluginAssignmentScope {
  team
  agent
  role_template
}

model PluginAssignment {
  assignmentId      String               @id @default(uuid()) @map("assignment_id")
  pluginId          String               @map("plugin_id")
  scopeType         PluginAssignmentScope @map("scope_type")
  scopeId           String               @map("scope_id")
  configuration     Json?
  enabled           Boolean              @default(true)
  assignedAt        DateTime             @default(now()) @map("assigned_at")
  assignedBy        String?              @map("assigned_by")

  plugin            PluginDefinition     @relation(fields: [pluginId], references: [pluginId], onDelete: Cascade)

  @@index([pluginId])
  @@index([scopeType, scopeId])
  @@map("plugin_assignments")
}

// Policy Violations
model PolicyViolation {
  violationId       String    @id @default(uuid()) @map("violation_id")
  policyId          String    @map("policy_id")
  scopeType         String    @map("scope_type")
  scopeId           String    @map("scope_id")
  actorId           String?   @map("actor_id")
  actorType         String?   @map("actor_type")
  targetType        String    @map("target_type")
  targetId          String    @map("target_id")
  actionAttempted   String    @map("action_attempted")
  context           Json?
  severity          String
  resolved          Boolean   @default(false)
  resolvedAt        DateTime? @map("resolved_at")
  resolvedBy        String?   @map("resolved_by")
  resolutionNote    String?   @map("resolution_note")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([policyId])
  @@index([scopeId])
  @@index([createdAt])
  @@map("policy_violations")
}

// Cost Budgets
enum BudgetPeriod {
  daily
  weekly
  monthly
  quarterly
  yearly
  project
}

enum BudgetAlertLevel {
  none
  info
  warning
  critical
}

model CostBudget {
  budgetId          String           @id @default(uuid()) @map("budget_id")
  companyId         String           @map("company_id")
  name              String
  description       String?
  scopeType         String           @map("scope_type")
  scopeId           String           @map("scope_id")
  budgetLimit       Decimal          @map("budget_limit") @db.Decimal(10, 2)
  period            BudgetPeriod     @default(monthly)
  startDate         DateTime         @map("start_date")
  endDate           DateTime?        @map("end_date")
  alertThresholds   Json?            @map("alert_thresholds")
  currentSpend      Decimal          @default(0) @map("current_spend") @db.Decimal(10, 2)
  lastAlertLevel    BudgetAlertLevel @default(none) @map("last_alert_level")
  lastAlertAt       DateTime?        @map("last_alert_at")
  enabled           Boolean          @default(true)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  company           Company          @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@index([companyId])
  @@index([scopeType, scopeId])
  @@map("cost_budgets")
}
